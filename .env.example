# 应用进程、HTTP 超时与 AI 提供方配置。
APP_ENV=development
APP_LOG_LEVEL=info
API_HTTP_ADDR=:8080
API_READ_HEADER_TIMEOUT=5s
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=30s
API_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s
WORKER_POLL_INTERVAL=2s
AI_BASE_URL=https://mgallery.haier.net/v1/
AI_MODEL=deepseek-v3
AI_API_KEY=
AI_REQUEST_TIMEOUT=25s
AI_CONFIDENCE_THRESHOLD=0.8

# 平台 PostgreSQL 管理账号和最小权限应用账号。
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=intelligent_report
POSTGRES_USER=report_admin
POSTGRES_PASSWORD=local_admin_password
POSTGRES_APP_USER=report_app
POSTGRES_APP_PASSWORD=local_report_password
DATABASE_URL=postgres://report_app:local_report_password@127.0.0.1:5432/intelligent_report?sslmode=disable

# 本地 MySQL 示例数据源与连接密钥引用内容。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=report_source
MYSQL_ROOT_PASSWORD=local_mysql_root_password
MYSQL_USER=report_reader
MYSQL_PASSWORD=local_mysql_reader_password
MYSQL_DSN="report_reader:local_mysql_reader_password@tcp(127.0.0.1:3306)/report_source?parseTime=true"
MYSQL_SOURCE_SECRET='{"host":"mysql","port":"3306","database":"report_source","username":"report_reader","password":"local_mysql_reader_password"}'

# 本地 Oracle 示例数据源。
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
ORACLE_PASSWORD=local_oracle_system_password
ORACLE_USER=report_reader
ORACLE_PASSWORD_APP=local_oracle_reader_password
ORACLE_DSN="oracle://report_reader:local_oracle_reader_password@127.0.0.1:1521/FREEPDB1"
ORACLE_SOURCE_SECRET='{"host":"oracle","port":"1521","database":"FREEPDB1","username":"report_reader","password":"local_oracle_reader_password"}'

# 隔离连接器服务及其连接、查询并发上限。
CONNECTOR_SERVICE_URL=http://127.0.0.1:8090
CONNECTOR_INTERNAL_TOKEN=local_connector_token_change_me
CONNECTOR_PORT=8090
CONNECTOR_MAX_CONNECTIONS_PER_SOURCE=5
CONNECTOR_MAX_CONCURRENT_QUERIES=10
CONNECTOR_POOL_IDLE_TTL_SECONDS=300

# 缓存与任务基础设施。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_password
REDIS_URL=redis://:local_redis_password@127.0.0.1:6379/0

# 对象存储端点和用途分离的桶名。
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_CONSOLE_ENDPOINT=http://127.0.0.1:9001
MINIO_ACCESS_KEY=report_minio
MINIO_SECRET_KEY=local_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_SNAPSHOTS=snapshots

# 认证令牌、刷新会话和密码哈希配置。
AUTH_TOKEN_ISSUER=intelligent-report-system
AUTH_ACCESS_TOKEN_SECRET=local_access_token_secret_change_me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_PASSWORD_BCRYPT_COST=12

# 本地开发种子租户与管理员账号。
SEED_TENANT_CODE=demo
SEED_TENANT_NAME=演示组织
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
