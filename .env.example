# 应用进程、HTTP 超时与 AI 提供方配置。
APP_ENV=development
APP_LOG_LEVEL=info
API_HTTP_ADDR=:8080
API_READ_HEADER_TIMEOUT=5s
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=60s
API_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s
WORKER_POLL_INTERVAL=2s
CONNECTION_TEST_TIMEOUT=30s
CONNECTION_TEST_LEASE=60s
# 远程模型端点必须使用 HTTPS；HTTP 仅允许 127.0.0.1/::1/localhost 本机代理。
AI_BASE_URL=https://mgallery.haier.net/v1/
AI_MODEL=deepseek-v3
AI_API_KEY=
AI_REQUEST_TIMEOUT=25s
AI_ATTEMPT_TIMEOUT=8s
AI_MAX_ATTEMPTS=3
AI_RETRY_BASE_DELAY=200ms
AI_RETRY_MAX_DELAY=2s
AI_MAX_INPUT_BYTES=262144
# 按模型账单配置每百万 Token 的微货币单位成本；0 表示只统计 Token、不估算费用。
AI_INPUT_COST_MICROS_PER_MILLION_TOKENS=0
AI_OUTPUT_COST_MICROS_PER_MILLION_TOKENS=0
AI_CONFIDENCE_THRESHOLD=0.8
# 向量模型独立于对话模型；未配置独立密钥时会复用 AI_API_KEY。
AI_EMBEDDING_BASE_URL=https://mgallery.haier.net/v1/
AI_EMBEDDING_MODEL=Qwen3-Embedding-4B
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_DIMENSIONS=2560
AI_EMBEDDING_TIMEOUT=15s
DATASET_AI_RETRIEVAL_MODE=HYBRID

# 平台控制面 PostgreSQL：保存系统、数据源、数据集、指标和治理元数据。
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=intelligent_report_control
POSTGRES_USER=report_admin
POSTGRES_PASSWORD=local_admin_password
POSTGRES_APP_USER=report_app
POSTGRES_APP_PASSWORD=local_report_password
POSTGRES_WORKER_USER=report_worker
POSTGRES_WORKER_PASSWORD=local_worker_password
POSTGRES_CONNECTION_TEST_USER=report_connection_tester
POSTGRES_CONNECTION_TEST_PASSWORD=local_connection_test_password
DATABASE_URL=postgres://report_app:local_report_password@127.0.0.1:5432/intelligent_report_control?sslmode=disable
WORKER_DATABASE_URL=postgres://report_worker:local_worker_password@127.0.0.1:5432/intelligent_report_control?sslmode=disable
CONNECTION_TEST_DATABASE_URL=postgres://report_connection_tester:local_connection_test_password@127.0.0.1:5432/intelligent_report_control?sslmode=disable

# ODS/DWD/DWS 数据面 PostgreSQL：独立实例、独立端口、独立账号和数据卷。
WAREHOUSE_POSTGRES_HOST=127.0.0.1
WAREHOUSE_POSTGRES_PORT=5433
WAREHOUSE_POSTGRES_DB=intelligent_report_warehouse
WAREHOUSE_POSTGRES_USER=warehouse_admin
WAREHOUSE_POSTGRES_PASSWORD=local_warehouse_admin_password
WAREHOUSE_READER_USER=report_warehouse_reader
WAREHOUSE_READER_PASSWORD=local_warehouse_reader_password
WAREHOUSE_WORKER_USER=report_warehouse_worker
WAREHOUSE_WORKER_PASSWORD=local_warehouse_worker_password
WAREHOUSE_DATABASE_URL=postgres://report_warehouse_reader:local_warehouse_reader_password@127.0.0.1:5433/intelligent_report_warehouse?sslmode=disable
WAREHOUSE_WORKER_DATABASE_URL=postgres://report_warehouse_worker:local_warehouse_worker_password@127.0.0.1:5433/intelligent_report_warehouse?sslmode=disable

# 隔离连接器服务及其连接、查询并发上限。
CONNECTOR_SERVICE_URL=http://127.0.0.1:8090
CONNECTOR_INTERNAL_TOKEN=local_connector_token_change_me
CONNECTOR_CONNECTION_TEST_TOKEN=local_connector_connection_test_token_change_me
CONNECTOR_PORT=8090
CONNECTOR_MAX_CONNECTIONS_PER_SOURCE=5
CONNECTOR_MAX_CONCURRENT_QUERIES=10
# Connector 进程级连接池数量和物理数据库连接硬上限；production 必须显式注入。
CONNECTOR_MAX_POOLS=1000
CONNECTOR_MAX_TOTAL_CONNECTIONS=100
CONNECTOR_POOL_IDLE_TTL_SECONDS=300
# HTTP 与样本响应预算（字节）。生产环境必须逐项显式注入，不能依赖程序默认值。
CONNECTOR_HTTP_MAX_REQUEST_BYTES=1048576
CONNECTOR_JSON_MAX_RESPONSE_BYTES=67108864
CONNECTOR_METADATA_SYNC_MAX_ROWS=200000
CONNECTOR_METADATA_SAMPLE_MAX_CELL_BYTES=16384
CONNECTOR_METADATA_SAMPLE_MAX_ROW_BYTES=65536
CONNECTOR_METADATA_SAMPLE_MAX_RESPONSE_BYTES=524288
# ODS NDJSON 的单元格、单行、整流预算，以及每个租户物化任务的逻辑落库预算。
# WAREHOUSE_STAGE_MAX_BYTES 同时约束数据库与 Excel/CSV staging；文件对象读取取
# 它与租户文件上限中的较小值，XLSX 展开再取解析器自身上限与该值中的较小值。
CONNECTOR_STREAM_MAX_CELL_BYTES=1048576
CONNECTOR_STREAM_MAX_ROW_BYTES=4194304
CONNECTOR_STREAM_MAX_BYTES=1073741824
WAREHOUSE_STAGE_MAX_BYTES=536870912
# 开发 compose 可按服务名授权。生产仅接受 IP/CIDR:port，例如
# 10.40.0.0/24:3306,10.50.8.12/32:1521；所有 DNS 解析地址都必须落在授权网段。
# production 还必须显式列出平台 PostgreSQL/Redis/MinIO/API 等控制面网段，deny 优先。
CONNECTOR_EGRESS_ALLOWLIST=
CONNECTOR_EGRESS_DENYLIST=
# 页面提交的数据库密码仅使用该 256 位密钥加密后进入控制库；生产环境必须独立生成并由密钥系统注入。
DATA_SOURCE_CREDENTIAL_KEY=bG9jYWxfZGF0YV9zb3VyY2VfY3JlZGVudGlhbF9rZXk=

# 缓存与任务基础设施。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_password
REDIS_URL=redis://:local_redis_password@127.0.0.1:6379/0

# 对象存储端点和用途分离的桶名。
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_CONSOLE_ENDPOINT=http://127.0.0.1:9001
MINIO_ACCESS_KEY=report_minio
MINIO_SECRET_KEY=local_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_SNAPSHOTS=snapshots
# 专用连接测试进程使用独立、只读 uploads 桶凭据；本地可复用 MinIO root，
# 生产必须显式注入受限账号，不能依赖下列开发值。
CONNECTION_TEST_MINIO_ENDPOINT=127.0.0.1:9000
CONNECTION_TEST_MINIO_ACCESS_KEY=report_minio
CONNECTION_TEST_MINIO_SECRET_KEY=local_minio_password
CONNECTION_TEST_MINIO_USE_SSL=false
CONNECTION_TEST_MINIO_BUCKET_UPLOADS=uploads

# 认证令牌、刷新会话和密码哈希配置。
AUTH_TOKEN_ISSUER=intelligent-report-system
AUTH_ACCESS_TOKEN_SECRET=local_access_token_secret_change_me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_PASSWORD_BCRYPT_COST=12

# 本地开发种子租户与管理员账号。
SEED_TENANT_CODE=demo
SEED_TENANT_NAME=演示组织
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
